{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Represents a staff member in the organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the employee." },
        "nip": { "type": "string", "description": "Employee identification number." },
        "name": { "type": "string", "description": "Full name of the employee." },
        "email": { "type": "string", "format": "email", "description": "Email address of the employee." },
        "skill": { "type": "string", "description": "Primary skill or team (e.g., MPBK, PBK)." },
        "channel": { "type": "string", "description": "Communication channel (e.g., Call, Chat)." },
        "site": { "type": "string", "description": "Work location or site." },
        "gender": { "type": "string", "enum": ["L", "P"], "description": "Gender (L for Male, P for Female)." },
        "religion": { "type": "string", "description": "Religion of the employee." },
        "role": { "type": "string", "description": "Job title or role of the employee." },
        "department": { "type": "string", "description": "Department the employee belongs to." },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "List of skills the employee possesses." },
        "preferredShifts": { "type": "array", "items": { "type": "string" }, "description": "List of shift codes this employee prefers or is restricted to." }
      },
      "required": ["name", "nip", "skill"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Represents a scheduled work period for an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the shift." },
        "employeeId": { "type": "string", "description": "ID of the employee assigned to this shift." },
        "employeeName": { "type": "string", "description": "Name of the employee (denormalized for display)." },
        "startTime": { "type": "string", "format": "date-time", "description": "Start time of the shift." },
        "endTime": { "type": "string", "format": "date-time", "description": "End time of the shift." },
        "type": { "type": "string", "enum": ["morning", "afternoon", "night"], "description": "Type of shift." },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"], "description": "Current status of the shift." }
      },
      "required": ["employeeId", "startTime", "endTime", "type", "status"]
    },
    "Forecast": {
      "title": "Forecast",
      "description": "Represents predicted staffing needs for a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the forecast." },
        "date": { "type": "string", "format": "date", "description": "The date for which the forecast is made." },
        "predictedDemand": { "type": "number", "description": "Predicted volume of work/customers." },
        "requiredStaffCount": { "type": "integer", "description": "Number of staff members required to meet the demand." }
      },
      "required": ["date", "predictedDemand", "requiredStaffCount"]
    },
    "ShiftCode": {
      "title": "Shift Code",
      "description": "Defines a shift pattern with a code and specific hours.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Short code for the shift (e.g., S1, M1)." },
        "name": { "type": "string", "description": "Descriptive name (e.g., Morning Shift)." },
        "startTime": { "type": "string", "description": "Start time in HH:mm format." },
        "endTime": { "type": "string", "description": "End time in HH:mm format." },
        "isNightShift": { "type": "boolean", "description": "Flag indicating if this is a night shift." }
      },
      "required": ["code", "name", "startTime", "endTime"]
    },
    "ForecastVolume": {
      "title": "Forecast Volume",
      "description": "Represents the work volume per interval for a specific date.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The date in YYYY-MM-DD format." },
        "day": { "type": "string", "description": "Day of the week (e.g., Mon, Tue)." },
        "totalVolume": { "type": "number", "description": "Total volume for the day." },
        "intervals": { "type": "object", "description": "Map of time intervals to volume values." }
      },
      "required": ["date", "day", "totalVolume", "intervals"]
    },
    "HistoricalVolume": {
      "title": "Historical Volume",
      "description": "Represents the historical work volume per interval for a specific date (used for AI training).",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The date in YYYY-MM-DD format." },
        "day": { "type": "string", "description": "Day of the week (e.g., Mon, Tue)." },
        "totalVolume": { "type": "number", "description": "Total volume for the day." },
        "intervals": { "type": "object", "description": "Map of time intervals to volume values." }
      },
      "required": ["date", "day", "totalVolume", "intervals"]
    },
    "WorkingDayRef": {
      "title": "Working Day Reference",
      "description": "Monthly reference for working days and offdays.",
      "type": "object",
      "properties": {
        "month": { "type": "string", "description": "Month and year (e.g., Jan-25)." },
        "totalDays": { "type": "number", "description": "Total days in the month." },
        "workingDays": { "type": "number", "description": "Number of working days." },
        "offday": { "type": "number", "description": "Number of offdays (weekends/holidays)." }
      },
      "required": ["month", "totalDays", "workingDays", "offday"]
    },
    "ErlangResult": {
      "title": "Erlang Result",
      "description": "Calculated staffing requirements using Erlang C.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "Date of the result." },
        "day": { "type": "string", "description": "Day of the week." },
        "totalAgents": { "type": "number", "description": "Total agents needed." },
        "peakAgents": { "type": "number", "description": "Peak agents needed." },
        "intervalNeeds": { "type": "object", "description": "Headcount needed per interval." },
        "shiftSuggestions": { "type": "object", "description": "Suggested shift distributions." },
        "intervalSupply": { "type": "object", "description": "Actual supply per interval." },
        "assignments": { "type": "object", "description": "Employee assignments." }
      },
      "required": ["date", "day", "totalAgents", "peakAgents", "intervalNeeds", "shiftSuggestions", "intervalSupply"]
    },
    "ErlangSettings": {
      "title": "Erlang Settings",
      "description": "Global settings for Erlang calculations.",
      "type": "object",
      "properties": {
        "aht": { "type": "number", "description": "Average Handle Time in seconds." },
        "targetSL": { "type": "number", "description": "Target Service Level percentage." },
        "targetTime": { "type": "number", "description": "Target time for Service Level in seconds." },
        "shrinkage": { "type": "number", "description": "Shrinkage percentage." }
      }
    },
    "Roster": {
      "title": "Roster",
      "description": "The current published roster.",
      "type": "object",
      "properties": {
        "roster": { "type": "array", "description": "List of employee rosters." }
      }
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "Represents a request for time off by an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the request." },
        "employeeId": { "type": "string", "description": "ID of the employee." },
        "employeeName": { "type": "string", "description": "Name of the employee." },
        "date": { "type": "string", "format": "date", "description": "The date for which leave is requested (YYYY-MM-DD)." },
        "type": { "type": "string", "enum": ["annual", "sick", "casual", "other"], "description": "Type of leave." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Current status of the request." },
        "reason": { "type": "string", "description": "Reason for the leave request." },
        "submittedAt": { "type": "string", "format": "date-time", "description": "When the request was submitted." }
      },
      "required": ["employeeId", "date", "status"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employee records."
    },
    "/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "Collection of scheduled shifts."
    },
    "/forecasts/{forecastId}": {
      "schema": "Forecast",
      "description": "Collection of staffing forecasts."
    },
    "/shiftCodes/{codeId}": {
      "schema": "ShiftCode",
      "description": "Collection of shift code definitions."
    },
    "/forecastVolume/{date}": {
      "schema": "ForecastVolume",
      "description": "Collection of daily volume data per interval."
    },
    "/historicalVolume/{date}": {
      "schema": "HistoricalVolume",
      "description": "Collection of historical daily volume data per interval."
    },
    "/workingDaysRef/{month}": {
      "schema": "WorkingDayRef",
      "description": "Collection of monthly working day references."
    },
    "/erlangResults/{id}": {
      "schema": "ErlangResult",
      "description": "Collection of Erlang calculation results."
    },
    "/erlangSettings/{id}": {
      "schema": "ErlangSettings",
      "description": "Global Erlang settings."
    },
    "/roster/{id}": {
      "schema": "Roster",
      "description": "The published roster."
    },
    "/leaveRequests/{requestId}": {
      "schema": "LeaveRequest",
      "description": "Collection of employee leave requests."
    }
  }
}
